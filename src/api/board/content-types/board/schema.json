{
  "kind": "collectionType",
  "collectionName": "boards",
  "info": {
    "singularName": "board",
    "pluralName": "boards",
    "displayName": "Board"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "description": {
      "type": "text"
    },
    "background": {
      "type": "string",
      "default": "#FFFFFF",
      "required": true
    },
    "owner": {
      "type": "relation",
      "relation": "OneToOne",
      "target": "plugin::users-permissions.user"
    },
    "workspace": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::workspace.workspace",
      "inversedBy": "boards"
    },
    "lists": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::list.list",
      "mappedBy": "board"
    }
  }
}
